# ===========================================
# Asad Shabir Portfolio — Backend Environment
# ===========================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ===========================================
# Server
# ===========================================
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173

# ===========================================
# Email (Resend API) — contact form delivery
# ===========================================
# Get your API key at https://resend.com
RESEND_API_KEY=re_9RsgGoC5_ggGxes77csatuik4ZGS8vBZd
RESEND_FROM_EMAIL=contact@asadshabir.com
RESEND_TO_EMAIL=asadshabir505@gmail.com

# ===========================================
# Gmail SMTP — chatbot email delivery (FROM Asad TO visitors)
# ===========================================
# Used by the chatbot when users ask "send me your resume" etc.
# GMAIL_APP_PASSWORD is an App Password generated from Google Account settings
# (not the regular Gmail password). Enable 2FA first then create App Password.
GMAIL_EMAIL=monkeyquest.ai@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Gemini API (AI services — Google AI Studio)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Groq API (fallback)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# ===========================================
# Rate Limiting
# ===========================================
# Requests per IP per window
CONTACT_RATE_LIMIT=5
CONTACT_RATE_WINDOW=3600
CHATBOT_RATE_LIMIT=10
CHATBOT_RATE_WINDOW=600

# ===========================================
# Analytics Admin
# ===========================================
# Password for the /api/admin/analytics dashboard
# Set this to a strong random value in production
ANALYTICS_PASSWORD=aLeeasaD_1&OnLy