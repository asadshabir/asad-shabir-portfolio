# Premium Portfolio — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ===========================================
# FRONTEND — Vite React (required for Vercel)
# ===========================================

# Chatbot API URL — set this in Vercel project settings
# Local dev:     VITE_API_URL=/chat (uses Vite proxy)
# Production:    VITE_API_URL=https://asadali110-portfolio.hf.space/chat
VITE_API_URL=/chat

# API base URL for other backend services (optional, dev only)
VITE_API_BASE_URL=http://localhost:8000

# ===========================================
# BACKEND — Python FastAPI (local dev only)
# ===========================================

# Resend API (email sending)
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Groq API (chatbot LLM)
# Get your API key at https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API (fallback LLM)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cohere API (RAG embeddings)
COHERE_API_KEY=cohere_xxxxxxxxxxxxxxxxxxxxxxxx

# Qdrant Vector DB
QDRANT_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.us-west-1-0.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
